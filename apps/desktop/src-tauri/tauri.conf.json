{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cc-branch",
  "version": "0.1.0",
  "identifier": "com.gemini-light.cc-branch",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../web && npm run dev",
    "beforeBuildCommand": "cd ../../web && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CC Branch Dashboard",
        "width": 960,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/cc-branch-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
