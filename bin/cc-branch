#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path


def _python_candidates() -> list[str]:
    override = os.environ.get("PYTHON_BIN")
    if override:
        return [override]
    return ["python3.11", "python3.12", "python3.13", "python3"]


def _supports_python_311(binary: str) -> bool:
    try:
        result = subprocess.run(
            [
                binary,
                "-c",
                "import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)",
            ],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
    except FileNotFoundError:
        return False
    return result.returncode == 0


def _select_python() -> str | None:
    for candidate in _python_candidates():
        if _supports_python_311(candidate):
            return candidate
    return None


def main() -> int:
    python_bin = _select_python()
    if python_bin is None:
        print("error: Python 3.11+ is required for cc-branch", file=sys.stderr)
        return 1

    script_dir = Path(__file__).resolve().parent
    project_root = script_dir.parent
    env = os.environ.copy()
    env["PYTHONPATH"] = str(project_root) + (os.pathsep + env["PYTHONPATH"] if env.get("PYTHONPATH") else "")

    completed = subprocess.run([python_bin, "-m", "cc_branch", *sys.argv[1:]], env=env, check=False)
    return completed.returncode


if __name__ == "__main__":
    raise SystemExit(main())
